#!/usr/bin/env bash
# BAISH — Bash-first terminal AI coding agent
# Usage: baish [directory]

set -o pipefail

BAISH_VERSION="0.1.0"

baish_usage() {
    cat <<EOF
BAISH — Bash-first terminal AI coding agent (v${BAISH_VERSION})

Usage: baish [directory]

Arguments:
  directory    Project directory to work in (default: \$PWD)

Environment variables:
  BAISH_MAX_TOOL_ROUNDS   Max tool call rounds per message (default: 50)
  BAISH_BASH_TIMEOUT      Shell command timeout in seconds (default: 120)
  BAISH_DEBUG             Enable debug logging: 0=off, 1=on (default: 0)

Slash commands:
  /help              Show this help
  /quit, /exit       Exit the agent
  /new               Clear conversation history
  /connect           Authenticate current provider and pick a model
  /provider          Switch providers interactively
  /model             Switch models interactively
  /skill:<name>      Load a skill into the session

EOF
}

# Resolve the script's own directory (follow symlinks for Docker symlink support)
BAISH_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"

# Source core modules
source "${BAISH_ROOT}/lib/agent/config.sh"
source "${BAISH_ROOT}/lib/state.sh"
source "${BAISH_ROOT}/lib/tools/tools.sh"
source "${BAISH_ROOT}/lib/agent/output.sh"
source "${BAISH_ROOT}/lib/agent/session.sh"
source "${BAISH_ROOT}/lib/agent/skills.sh"
source "${BAISH_ROOT}/lib/agent/agents-md.sh"
source "${BAISH_ROOT}/lib/agent/commands.sh"
source "${BAISH_ROOT}/lib/agent/run-loop.sh"
source "${BAISH_ROOT}/lib/providers/discovery.sh"
source "${BAISH_ROOT}/lib/providers/chat-parser.sh"
source "${BAISH_ROOT}/lib/agent/startup.sh"
source "${BAISH_ROOT}/lib/ui/completion.sh"

# Parse arguments
BAISH_LAUNCH_DIR="${1:-$(pwd)}"
if [[ "${BAISH_LAUNCH_DIR}" == "--help" || "${BAISH_LAUNCH_DIR}" == "-h" ]]; then
    baish_usage
    exit 0
fi

# Validate launch directory
if [[ ! -d "${BAISH_LAUNCH_DIR}" ]]; then
    baish_output_error "Directory not found: ${BAISH_LAUNCH_DIR}"
    exit 1
fi
cd "${BAISH_LAUNCH_DIR}" || exit 1

baish_debug "BAISH v${BAISH_VERSION} starting in ${BAISH_LAUNCH_DIR}"

# Initialize state directory
baish_state_init

# Discover all providers
baish_discover_providers

# Initialize agent instructions (AGENTS.md) — loaded once, survives /new
baish_agents_md_init

# Startup: select provider and model
if ! baish_startup; then
    exit 1
fi

# Scan available skills before displaying context summary
baish_skill_scan_available

baish_output_banner
baish_output_info "Provider: ${BAISH_CURRENT_PROVIDER} | Model: ${BAISH_CURRENT_MODEL}"
baish_output_context_summary

# Main interactive loop
baish_main_loop() {
    while (( ! BAISH_SESSION_EXIT_REQUESTED )); do
        local user_input

        if ! user_input=$(baish_read_input); then
            # EOF (Ctrl+D)
            printf "\n"
            break
        fi

        # Trim whitespace from each line and rejoin
        user_input=$(echo "${user_input}" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        [[ -z "${user_input}" ]] && continue

        # Handle slash commands
        if [[ "${user_input}" == /* ]]; then
            baish_dispatch_command "${user_input}"
            continue
        fi

        # Run agent loop for user message
        baish_agent_run_user_message "${user_input}"
    done
}

# Initialize readline completion
baish_setup_completion

# Bind Alt+Enter to insert backslash + newline for multiline continuation
bind '"\e\r": "\\\n"' 2>/dev/null || true

# Read input with Alt+Enter multiline support.
# Alt+Enter inserts a backslash at end of line; we detect it and continue
# reading until the user submits without a trailing backslash.
baish_read_input() {
    local result=""
    local line

    # Build the readline-safe prompt with \001/\002 ANSI delimiters so
    # readline knows the prompt width and doesn't overwrite it during
    # TAB completion redraws.
    local prompt
    prompt=$(baish_output_readline_prompt "${BAISH_CURRENT_PROVIDER}" "${BAISH_CURRENT_MODEL}")

    if ! read -e -p "${prompt}" -r line; then
        return 1
    fi
    result="${line}"

    # Check for continuation (trailing backslash from Alt+Enter)
    while [[ "${result}" == *\\ ]]; do
        # Remove trailing backslash
        result="${result%\\}"
        if ! read -e -p "${prompt}" -r line; then
            return 1
        fi
        result="${result}
${line}"
    done

    printf '%s' "${result}"
    return 0
}

baish_main_loop
baish_output_info "Goodbye!"